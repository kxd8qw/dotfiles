{{- if eq .chezmoi.os "linux" -}}
font-family = "CaskaydiaCove Nerd Font Propo"
font-size = 11
{{- else }}
font-family = "CaskaydiaCove Nerd Font Mono"
font-size = 12
{{- end }}
# programming ligatures (contextual, discretionary, transforms)
font-feature = +calt,+dlig,+liga
font-thicken = true

# theme = "GitHub Dark"
{{ if eq .chezmoi.os "linux" -}}
# theme = "dark:Catppuccin Mocha,light:Catppuccin Latte"
{{- else }}
theme = "dark:Catppuccin Mocha,light:Catppuccin Latte"
{{- end }}
cursor-opacity = 1
cursor-style = block
cursor-style-blink = false
{{- if eq .chezmoi.os "linux" }}
background-opacity = 0.85
{{- else }}
background-opacity = 0.6
{{- end }}
unfocused-split-opacity = 0.65
background-blur = 10
background-blur-radius = 20
bold-is-bright = true
background = #1D1D20
foreground = #CDD6F4
selection-background = #CDD6F4
selection-foreground = #1D1D20
cursor-color = #A6E3A1
cursor-text = #101020
palette = 0=#45475A
palette = 1=#F38BA8
palette = 2=#A6E3A1
palette = 3=#F9E2AF
palette = 4=#89B4FA
palette = 5=#F5C2E7
palette = 6=#94E2D5
palette = 7=#BAC2DE
palette = 8=#585B70
palette = 9=#F38BA8
palette = 10=#A6E3A1
palette = 11=#F9E2AF
palette = 12=#89B4FA
palette = 13=#F5C2E7
palette = 14=#94E2D5
palette = 15=#A6ADC8

# Hide the mouse pointer while typing, matching GNOME Terminal/Ptyxis behavior
mouse-hide-while-typing = true
scrollback-limit = 10000000
scrollbar = system
focus-follows-mouse = true

shell-integration = detect
shell-integration-features = no-cursor,ssh-env,ssh-terminfo,sudo,title

window-inherit-working-directory = true
window-step-resize = true
window-height = 33
window-width = 100
window-save-state = always
resize-overlay = always
window-new-tab-position = current
# Show current working directory in the window subtitle
window-subtitle = working-directory
# Extend the terminal background color into the window padding for seamless look
window-padding-color = extend
window-padding-balance = true
window-padding-x = 8
window-padding-y = 4

# clipboard protection
clipboard-read = ask
clipboard-write = allow
clipboard-paste-protection = true
copy-on-select = true

# prevent title query attacks
title-report = false
clipboard-trim-trailing-spaces = true

# merge titlebar and tabs
gtk-titlebar-style = tabs
macos-titlebar-style = tabs

# Fast Linux startup
gtk-single-instance = desktop

# Send a desktop notification when a command finishes in an unfocused window —
# useful for long distrobox builds
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify

keybind = ctrl+page_up=previous_tab
keybind = ctrl+page_down=next_tab
keybind = ctrl+shift+up=jump_to_prompt:-1
keybind = ctrl+shift+down=jump_to_prompt:1
# F11 is the GNOME standard for fullscreen (overrides Ghostty's Ctrl+Enter default)
keybind = f11=toggle_fullscreen